# Copy to `.env` and fill in real values. Do NOT commit `.env`.

# --- Database (Aurora PostgreSQL) ---
# Prisma connects via the node-postgres driver adapter, which is wire-compatible
# with Aurora PostgreSQL. Point this at your Aurora cluster writer endpoint.
#   postgresql://USER:PASSWORD@<cluster-endpoint>:5432/<db>?sslmode=require
# For local development you can use a local/Docker Postgres instead:
#   postgresql://postgres:postgres@localhost:5432/typeforge?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/typeforge?sslmode=require"

# --- Auth.js (NextAuth v5) ---
# Secret used to sign and encrypt the session JWT. Generate one with:
#   openssl rand -base64 33
AUTH_SECRET="replace-me"

# Optional: only needed if auto-detection of the deployment URL is wrong (e.g. behind a proxy).
# AUTH_URL="https://your-domain.com"

# --- Social login (optional) ---
# The Google + GitHub buttons appear on the auth pages always, but only work once
# you fill these in. Leave blank to keep them disabled.
#
# Google:  https://console.cloud.google.com/  -> Credentials -> OAuth client ID (Web)
#   Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
#
# GitHub:  https://github.com/settings/developers -> New OAuth App
#   Authorization callback URL: http://localhost:3000/api/auth/callback/github
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""
